// ============================================
// AI AGENT BUILDING PROJECTS
// ============================================

model AIAgentBuildingProject {
  id          String @id @default(uuid()) @map("_id")
  slug        String @unique
  name        String
  description String

  image    String
  images   String[] @default([])
  badge    String?
  popular  Boolean  @default(false)
  featured Boolean  @default(false)

  clientName     String?
